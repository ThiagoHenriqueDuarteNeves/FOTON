/**
 * Given a list of elements, this function removes duplicate items from it.
 */
fun removeDuplicates(elements: List<Any>): List<Any> {
    return elements.toSet().toList()
}

// Example usage
val myElements = listOf("A", "B", "C", "A", "D", "E", "F", "B")
val uniqueElements = removeDuplicates(myElements)
println(uniqueElements)  // Output: [A, B, C, D, E, F]
