import json
from selenium import webdriver
from bs4 import BeautifulSoup

# Inicializa o navegador
driver = webdriver.Chrome()

# Navega para a página
driver.get("https://example.com")  # Substitua pela URL da sua página

# Aguarda a página carregar completamente
driver.implicitly_wait(10)

# Extrai o HTML da página e cria um objeto BeautifulSoup
soup = BeautifulSoup(driver.page_source, "html.parser")

# Seleciona os elementos interativos
elements = soup.select(".nav-link.text-primary.text-uppercase.fw-bold.btn-menu")
elements += soup.select(".btn.btn-primary.text-uppercase.fw-bold")
elements += soup.select(".btn.btn-secondary.ng-star-inserted")

# Cria uma lista com os textos e seletores dos elementos encontrados
element_data = [{"text": element.get_text(), "selector": element["class"][0]} for element in elements]

# Encerra o navegador
driver.quit()

# Retorna a resposta em JSON, sem explicações nem markdown
print(json.dumps({"elements": element_data}, indent=2))

